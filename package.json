{
  "name": "@anilkumarthakur/collection",
  "version": "0.0.0",
  "description": "A fluent, Laravel-inspired Collection library for JavaScript and TypeScript. Provides 120+ chainable methods for elegant array manipulation.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "/dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anilkumarthakur60/collection-js.git"
  },
  "homepage": "https://github.com/anilkumarthakur60/collection-js#readme",
  "bugs": {
    "url": "https://github.com/anilkumarthakur60/collection-js/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest",
    "lint": "eslint . --fix",
    "format": "prettier --write src/ docs/",
    "lint-format": "npm run lint && npm run format",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "ctf": "clear && npm run format && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4"
  },
  "keywords": [
    "collection",
    "data-structure",
    "typescript",
    "javascript",
    "library",
    "laravel",
    "laravel-collections",
    "collection-js",
    "collection-ts",
    "array",
    "fluent",
    "chainable",
    "functional",
    "manipulation"
  ]
}
